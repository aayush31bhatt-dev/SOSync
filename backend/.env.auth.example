# Authentication / JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXP_MINUTES=30
JWT_REMEMBER_ME_DAYS=30
PASSWORD_RESET_EXP_MINUTES=20

# Frontend reset URL
FRONTEND_RESET_URL=https://your-frontend/reset-password

# SMTP email delivery (required for real forgot-password emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=Smart Community SOS <your-email@example.com>
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10

# Dev-only fallback: log reset links if SMTP is unavailable
AUTH_DEBUG_RESET_LINKS=false

# API deployment settings
ALLOWED_ORIGINS=*
SMARTCOMMUNITY_DB_PATH=/var/data/smartcommunity.db
